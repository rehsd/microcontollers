0796                  static inline void copy_bytes(unsigned char* dst, const unsigned char* src, unsigned short count)
0797                  {
0798                      while (count--) {
0799                          *dst++ = *src++;
0800                      }
0801                  }
0802                  
0803                  static inline void clear_bytes(unsigned char* dst, unsigned short count)
0804                  {
0805                      while (count--) {
0806                          *dst++ = 0;
0807                      }
0808                  }
0809                  
0810                  static inline void copy512(unsigned char* dst, const unsigned char* src)
0811                  {
0812                      for (unsigned short i = 0; i < 512; i++) {
0813                          dst[i] = src[i];
0814                      }
0815                  }
