0211                          for (unsigned char x = 0; x < 32; x++) {
0212                              unsigned short c565 = rehsd_raw_565[i++];
0213                              
0214                              if (c565 != 0x0000) {
0215                                  // Convert 16-bit 565 to 8-bit 332
0216                                  // Red:   ((c >> 11) & 0x1F) -> scale to 3 bits
0217                                  // Green: ((c >> 5) & 0x3F)  -> scale to 3 bits
0218                                  // Blue:  (c & 0x1F)         -> scale to 2 bits
0219                                  unsigned char r = (unsigned char)((c565 >> 13) & 0x07);
0220                                  unsigned char g = (unsigned char)((c565 >> 8) & 0x07);
0221                                  unsigned char b = (unsigned char)((c565 >> 3) & 0x03);
