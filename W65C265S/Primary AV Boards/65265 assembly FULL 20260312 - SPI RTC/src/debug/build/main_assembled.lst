0225                                      (unsigned short)(startX + (x << 2)), 
0226                                      (unsigned short)(startY + (y << 2)), 
0227                                      4, 4, 
0228                                      c332, 1
0229                                  );
0230                              }
0231                          }
0232                          // One delay per row to keep the bus happy
0233                          delay(3); 
0234                      }
