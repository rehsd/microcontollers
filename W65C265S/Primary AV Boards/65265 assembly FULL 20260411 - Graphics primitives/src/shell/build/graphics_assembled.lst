0051                              unsigned short c565 = rehsd_raw_565[i++];
0052                              
0053                              if (c565 != 0x0000) {
0054                                  // Convert 16-bit 565 to 8-bit 332
0055                                  // Red:   ((c >> 11) & 0x1F) -> scale to 3 bits
0056                                  // Green: ((c >> 5) & 0x3F)  -> scale to 3 bits
0057                                  // Blue:  (c & 0x1F)         -> scale to 2 bits
0058                                  unsigned char r = (unsigned char)((c565 >> 13) & 0x07);
0059                                  unsigned char g = (unsigned char)((c565 >> 8) & 0x07);
0060                                  unsigned char b = (unsigned char)((c565 >> 3) & 0x03);
0061                                  unsigned char c332 = (unsigned char)((r << 5) | (g << 2) | b);
0062                  
