0835                  static inline void copy_bytes(unsigned char* dst, const unsigned char* src, unsigned short count)
0836                  {
0837                      while (count--) {
0838                          *dst++ = *src++;
0839                      }
0840                  }
0841                  
0842                  static inline void clear_bytes(unsigned char* dst, unsigned short count)
0843                  {
0844                      while (count--) {
0845                          *dst++ = 0;
0846                      }
0847                  }
0848                  
0849                  // Specialized for 512-byte sector copies
0850                  static inline void copy512(unsigned char* dst, const unsigned char* src)
0851                  {
0852                      for (unsigned short i = 0; i < 512; i++) {
0853                          dst[i] = src[i];
0854                      }
0855                  }
