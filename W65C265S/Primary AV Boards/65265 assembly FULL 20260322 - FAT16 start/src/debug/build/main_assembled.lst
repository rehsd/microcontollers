    \ 000006 1b                   tcs
    \ 000007 98                   tya
0305                      short startX = centerX - 64; 
    \ 000008 38                   sec
    \ 000009 e94000               sbc     ##64
    \ 00000c 8301                 sta     1,s
0306                      short startY = centerY - 64;
    \ 00000e a5..                 lda     dp:.tiny _Dp
    \ 000010 38                   sec
    \ 000011 e94000               sbc     ##64
    \ 000014 8303                 sta     3,s
0307                      unsigned short i = 0;
    \ 000016 a90000               lda     ##0
    \ 000019 8305                 sta     5,s
0308                  
0309                      for (unsigned char y = 0; y < 32; y++) {
    \ 00001b e220                 sep     #32
    \ 00001d a900                 lda     #0
    \ 00001f 8307                 sta     7,s
    \ 000021 c220                 rep     #32
    \ 000023 a305                 lda     5,s
