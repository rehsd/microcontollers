    \ 000031 e220                 sep     #32
    \ 000033 c920                 cmp     #32
    \ 000035 c220                 rep     #32
    \ 000037 9007                 bcc     `?L88`
0310                          for (unsigned char x = 0; x < 32; x++) {
0311                              unsigned short c565 = rehsd_raw_565[i++];
0312                              
0313                              if (c565 != 0x0000) {
0314                                  // Convert 16-bit 565 to 8-bit 332
0315                                  // Red:   ((c >> 11) & 0x1F) -> scale to 3 bits
0316                                  // Green: ((c >> 5) & 0x3F)  -> scale to 3 bits
0317                                  // Blue:  (c & 0x1F)         -> scale to 2 bits
0318                                  unsigned char r = (unsigned char)((c565 >> 13) & 0x07);
0319                                  unsigned char g = (unsigned char)((c565 >> 8) & 0x07);
0320                                  unsigned char b = (unsigned char)((c565 >> 3) & 0x03);
0321                                  unsigned char c332 = (unsigned char)((r << 5) | (g << 2) | b);
0322                  
0323                                  os_draw_rectangle(
0324                                      (unsigned short)(startX + (x << 2)), 
0325                                      (unsigned short)(startY + (y << 2)), 
0326                                      4, 4, 
0327                                      c332, 1
0328                                  );
0329                              }
0330                          }
0331                          // One delay per row to keep the bus happy
0332                          delay(3); 
0333                      }
