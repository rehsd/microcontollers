    \ 000000                      .section farcode,text
    \ 000000                      .public rgb332
    \ 000000 5a       rgb332:     phy
    \ 000001 5a                   phy
    \ 000002 5a                   phy
0192                      // RRRGGGBB
0193                      // Red:   Take top 3 bits (7,6,5), keep them at 7,6,5
0194                      // Green: Take top 3 bits (7,6,5), shift right 3 to positions 4,3,2
0195                      // Blue:  Take top 2 bits (7,6),   shift right 6 to positions 1,0
0196                      
0197                      unsigned short r_part = (unsigned short)(r & 0xE0);
    \ 000003 29e000               and     ##224
    \ 000006 29ff00               and     ##255
    \ 000009 8301                 sta     1,s
