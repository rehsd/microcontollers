    \ 00000b a9e000               lda     ##224
    \ 00000e 230a                 and     10,s
    \ 000010 29ff00               and     ##255
    \ 000013 4a                   lsr     a
    \ 000014 4a                   lsr     a
    \ 000015 4a                   lsr     a
    \ 000016 8303                 sta     3,s
0199                      unsigned short b_part = (unsigned short)(b & 0xC0) >> 6;
    \ 000018 a9c000               lda     ##192
    \ 00001b 230c                 and     12,s
    \ 00001d 29ff00               and     ##255
    \ 000020 4a                   lsr     a
    \ 000021 4a                   lsr     a
    \ 000022 4a                   lsr     a
    \ 000023 4a                   lsr     a
    \ 000024 4a                   lsr     a
    \ 000025 4a                   lsr     a
    \ 000026 8305                 sta     5,s
0200                  
0201                      return (unsigned short)(r_part | g_part | b_part);
