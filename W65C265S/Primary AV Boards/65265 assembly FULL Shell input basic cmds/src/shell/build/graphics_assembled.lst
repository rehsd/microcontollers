0048                              unsigned short c565 = rehsd_raw_565[i++];
0049                              
0050                              if (c565 != 0x0000) {
0051                                  // Convert 16-bit 565 to 8-bit 332
0052                                  // Red:   ((c >> 11) & 0x1F) -> scale to 3 bits
0053                                  // Green: ((c >> 5) & 0x3F)  -> scale to 3 bits
0054                                  // Blue:  (c & 0x1F)         -> scale to 2 bits
0055                                  unsigned char r = (unsigned char)((c565 >> 13) & 0x07);
0056                                  unsigned char g = (unsigned char)((c565 >> 8) & 0x07);
0057                                  unsigned char b = (unsigned char)((c565 >> 3) & 0x03);
0058                                  unsigned char c332 = (unsigned char)((r << 5) | (g << 2) | b);
0059                  
0060                                  os_draw_rectangle(
0061                                      (unsigned short)(startX + (x << 2)), 
0062                                      (unsigned short)(startY + (y << 2)), 
0063                                      4, 4, 
0064                                      c332, 1
0065                                  );
0066                              }
0067                          }
0068                          // One delay per row to keep the bus happy
0069                          delay(3); 
0070                      }
0071                  }
