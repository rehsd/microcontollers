0223                                                             ((unsigned long)p[31] << 24);
0224                                  
0225                                  // This routine must print the number and then pad with spaces to 15 chars
0226                                  print_padded_dec32(actual_size); 
0227                              }
0228                  
0229                              // Print Filename (Starts at column 16)
0230                              for (char j = 0; j < 8; j++) {
0231                                  if (entries[i].filename[j] != ' ') os_print_char(entries[i].filename[j]);
0232                              }
0233                  
0234                              // Print Extension
0235                              if (entries[i].extension[0] != ' ') {
0236                                  os_print_char('.');
0237                                  for (char j = 0; j < 3; j++) {
0238                                      if (entries[i].extension[j] != ' ') os_print_char(entries[i].extension[j]);
0239                                  }
0240                              }
0241                              os_newline();
0242                          }
0243                      }
0244                  }
