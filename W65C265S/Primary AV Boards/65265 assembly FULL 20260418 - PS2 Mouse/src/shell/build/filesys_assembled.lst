    \ 0000cb d007                 bne     `?L116`
    \ 0000cd          `?L68`:
0186                              if (first_char == (unsigned char)0xE5) continue;
0187                              if (attr == 0x0F) continue; 
0188                              if ((attr & 0x08) && !(attr & 0x10)) continue;
0189                  
0190                              // Unpack Date
0191                              unsigned short d = entries[i].write_date;
0192                              unsigned short year = (d >> 9) + 1980;
0193                              unsigned char month = (d >> 5) & 0x0F;
0194                              unsigned char day   = d & 0x1F;
0195                  
0196                              // Unpack Time
0197                              unsigned short t = entries[i].write_time;
0198                              unsigned char hour = (t >> 11) & 0x1F;
0199                              unsigned char min  = (t >> 5) & 0x3F;
0200                  
0201                              // Print Timestamp (MM/DD/YYYY HH:MM)
0202                              print_dec8(month);
0203                              os_print_char('/');
0204                              print_dec8(day);
0205                              os_print_char('/');
0206                              print_dec_year(year);
0207                              os_puts("  ");
0208                              print_dec8(hour);
0209                              os_print_char(':');
0210                              print_dec8(min);
0211                              os_puts("  ");
0212                  
0213                              // --- Handle Type and File Size (Decimal with Fixed 15-character Column) ---
