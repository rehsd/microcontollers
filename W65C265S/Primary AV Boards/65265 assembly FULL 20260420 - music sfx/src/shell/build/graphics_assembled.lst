0452                      // RRRGGGBB
0453                      // Red:   Take top 3 bits (7,6,5), keep them at 7,6,5
0454                      // Green: Take top 3 bits (7,6,5), shift right 3 to positions 4,3,2
0455                      // Blue:  Take top 2 bits (7,6),   shift right 6 to positions 1,0
0456                      
0457                      unsigned short r_part = (unsigned short)(r & 0xE0);
    \ 000003 29e000               and     ##224
    \ 000006 29ff00               and     ##255
