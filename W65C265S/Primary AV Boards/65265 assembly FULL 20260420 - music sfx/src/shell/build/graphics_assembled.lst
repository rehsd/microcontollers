    \ 000023 4a                   lsr     a
    \ 000024 4a                   lsr     a
    \ 000025 4a                   lsr     a
    \ 000026 8305                 sta     5,s
0460                  
0461                      return (unsigned short)(r_part | g_part | b_part);
